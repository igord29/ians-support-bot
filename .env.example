# ─── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=          # From @BotFather
TELEGRAM_CHAT_ID=            # Your personal chat ID (get from @userinfobot)
ALLOWED_TELEGRAM_USER_IDS=   # Your Telegram user ID (comma-separated for multiple)

# ─── Google (Service Account) ────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=   # service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY=     # Paste the full private_key from your JSON credentials
GOOGLE_CALENDAR_ID=primary      # or specific calendar ID
GOOGLE_TASKLIST_ID=             # Leave blank to use default, or paste specific list ID

# ─── Gmail ───────────────────────────────────────────────────
GMAIL_FROM_ADDRESS=             # your@gmail.com
GMAIL_USER_ID=me                # Usually 'me'
GOOGLE_OAUTH_CLIENT_ID=         # From Google Cloud Console
GOOGLE_OAUTH_CLIENT_SECRET=     # From Google Cloud Console
GMAIL_REFRESH_TOKEN=            # From OAuth2 flow (see scripts/gmail-auth.js)

# ─── OpenAI (Whisper voice transcription) ───────────────
OPENAI_API_KEY=              # From platform.openai.com

# ─── App ─────────────────────────────────────────────────────
PORT=3000
DB_PATH=./data/agent.db
