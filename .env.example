# ─── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=          # From @BotFather
TELEGRAM_CHAT_ID=            # Your personal chat ID (get from @userinfobot)
ALLOWED_TELEGRAM_USER_IDS=   # Your Telegram user ID (comma-separated for multiple)

# ─── Google (Service Account) ────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=   # service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY=     # Paste the full private_key from your JSON credentials
GOOGLE_CALENDAR_ID=primary      # or specific calendar ID
GOOGLE_TASKLIST_ID=             # Leave blank to use default, or paste specific list ID

# ─── Gmail ───────────────────────────────────────────────────
GMAIL_FROM_ADDRESS=             # your@gmail.com
GMAIL_USER_ID=me                # Usually 'me'
GOOGLE_OAUTH_CLIENT_ID=         # From Google Cloud Console
GOOGLE_OAUTH_CLIENT_SECRET=     # From Google Cloud Console
GMAIL_REFRESH_TOKEN=            # From OAuth2 flow (see scripts/gmail-auth.js)

# ─── OpenAI (Whisper voice transcription) ───────────────
OPENAI_API_KEY=              # From platform.openai.com

# ─── App ─────────────────────────────────────────────────────
PORT=3000
DB_PATH=./data/agent.db
WEBHOOK_URL=                    # Your public URL (e.g. https://your-app.onrender.com) — webhook auto-registers on startup

# ─── UnitedSets (unitedsets.com tournament/match-play tools) ─
UNITEDSETS_SUPABASE_URL=        # https://azxnvsytmmcdcrlgpagz.supabase.co
UNITEDSETS_SUPABASE_SERVICE_KEY=# Service role key (Supabase → Settings → API). Writes are approval-gated.
UNITEDSETS_ADMIN_USER_ID=1      # users.id recorded as created_by on rows the bot creates
UNITEDSETS_CONTACT_EMAIL=       # Default contact_email for bot-created tournaments
UNITEDSETS_CONTACT_PHONE=       # Default contact_phone for bot-created tournaments

# ─── GitHub (repo tools) ─────────────────────────────────────
GITHUB_TOKEN=                   # Fine-grained PAT: Contents R/W + Pull requests R/W on your repos
GITHUB_OWNER=igord29            # Account the bot may act on (never other owners)
GITHUB_ALLOWED_REPOS=           # Optional comma-separated allow-list; blank = all repos under GITHUB_OWNER

# ─── Vercel (deploy tools) ───────────────────────────────────
VERCEL_TOKEN=                   # vercel.com → Account Settings → Tokens (for status/logs)
VERCEL_TEAM_ID=                 # Only if your projects live in a team
VERCEL_DEPLOY_HOOK_URL=         # Project → Settings → Git → Deploy Hooks (for trigger_deploy)

# ─── Web search ──────────────────────────────────────────────
BRAVE_API_KEY=                  # brave.com/search/api (free tier) — web_fetch needs no key

# ─── USTA tournament watcher ─────────────────────────────────
# Watches Gmail for USTA notification emails (the USTA site itself blocks bots),
# notifies on Telegram, and offers to create the tournament on unitedsets.com.
# Requires gmail.readonly scope — re-run scripts/gmail-auth.js to get a new
# refresh token after enabling.
USTA_WATCH=                     # "on" to enable the 15-min inbox check
USTA_EMAIL_QUERY=               # Optional Gmail query override (default: from USTA domains, last 3 days)

# ─── Persona (per-deployment) ────────────────────────────────
# Run a second bot for a different person from this same codebase by giving
# that deployment its own values here. Leave blank to default to Ian.
AGENT_OWNER_NAME=               # Name used in greetings, e.g. "Sarah" (defaults to "Ian")
AGENT_SYSTEM_PROMPT=            # Full system prompt override. Leave blank to use the built-in default.
